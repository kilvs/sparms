{%- liquid
  assign cta_url = section.settings.cta_url
  if cta_url == blank and section.settings.cta_product != blank
    assign cta_url = section.settings.cta_product.url
  endif
  if cta_url == blank and section.settings.cta_collection != blank
    assign cta_url = section.settings.cta_collection.url
  endif
  assign cta_url = cta_url | default: routes.collections_url | append: '/all'
-%}
{%- if section.settings.show_section -%}
      <section class="component_cta_section">
        <div class="padding-global padding-section-medium">
          <div class="container-large">
            <div class="component_cta_wrapper">
              <div class="component_cta_content_wrapper">
                <h2>{{ section.settings.heading | default: 'PERFORM UNDER PRESSURE with THE ORIGINAL SUN SLEEVE' }}</h2>
                <div class="max-width-xsmall">
                  <p>{{ section.settings.body | default: 'Join thousands of athletes protecting their skin with our high-performance sun sleeves.' }}</p>
                </div>
              </div>
              {%- if section.settings.show_cta -%}
                <div class="component_cta_button_wrapper">
                  <a href="{{ cta_url }}" class="button is-secondary is-icon is-alternate w-inline-block">
                    <div class="button-icon w-embed"><svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 13 13" fill="none" preserveaspectratio="xMidYMid meet" aria-hidden="true" role="img">
                        <circle cx="6.5" cy="6.5" r="6.5" fill="currentColor"></circle>
                      </svg></div>
                    <div>{{ section.settings.cta_label | default: 'SHOP ALL' }}</div>
                  </a>
                </div>
              {%- endif -%}
            </div>
          </div>
        </div>
      </section>
{%- endif -%}

{% schema %}
{
  "name": "CTA",
  "tag": "section",
  "class": "shopify-section-component-cta",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show this section", "default": true },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "PERFORM UNDER PRESSURE with THE ORIGINAL SUN SLEEVE" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Join thousands of athletes protecting their skin with our high-performance sun sleeves." },
    { "type": "header", "content": "Call to action" },
    { "type": "checkbox", "id": "show_cta", "label": "Show CTA button", "default": true },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "SHOP ALL" },
    { "type": "product", "id": "cta_product", "label": "Linked product (optional)" },
    { "type": "collection", "id": "cta_collection", "label": "Linked collection (optional)" },
    { "type": "url", "id": "cta_url", "label": "Custom URL (overrides product/collection)" }
  ],
  "presets": [{ "name": "CTA" }]
}
{% endschema %}
