<section class="not-found_section">
  <div class="padding-section-large">
    <div class="page-width">
      <div class="max-width-large align-center text-align-center">
        <h1>{{ section.settings.heading | default: 'Page not found' }}</h1>
        <div class="spacer-medium"></div>
        <p>{{ section.settings.body | default: "The page you're looking for can't be found. It may have been moved or no longer exists." }}</p>
        <div class="spacer-medium"></div>
        <div class="button-group" style="justify-content:center;">
          <a href="{{ routes.root_url }}" class="button-primary w-button">{{ section.settings.cta_label | default: 'Back to home' }}</a>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "404",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Page not found" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "The page you're looking for can't be found. It may have been moved or no longer exists." },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Back to home" }
  ]
}
{% endschema %}
