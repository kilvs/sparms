{%- if section.settings.show_section -%}
      <section class="component_ambassadors_section">
        <div class="w-embed w-script">
          <style>
@media (min-width: 992px) and (max-width: 1239px) {
  .component_ambassadors_list { display: grid; grid-template-columns: repeat(3, 1fr); align-items: start; }
  .component_ambassadors_list-item:nth-child(3n+2) { margin-top: 200px; margin-left: -25%; }
  .component_ambassadors_list-item { margin-bottom: -80px; }
  .component_ambassadors_list-item:nth-child(1),
  .component_ambassadors_list-item:nth-child(2),
  .component_ambassadors_list-item:nth-child(3) { margin-bottom: -120px; }
}
@media (min-width: 1240px) {
  .component_ambassadors_list { display: grid; grid-template-columns: repeat(4, 1fr); align-items: start; }
  .component_ambassadors_list-item:nth-child(4n+2),
  .component_ambassadors_list-item:nth-child(4n+4) { margin-top: 200px; margin-left: -25%; }
  .component_ambassadors_list-item { margin-bottom: -80px; }
  .component_ambassadors_list-item:nth-child(1),
  .component_ambassadors_list-item:nth-child(2),
  .component_ambassadors_list-item:nth-child(3) { margin-bottom: -120px; }
}
  </style>
          <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>
          <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js"></script>
          <script>
  document.addEventListener('DOMContentLoaded', () => {
    gsap.registerPlugin(ScrollTrigger);
    const mm = gsap.matchMedia();
    mm.add("(min-width: 992px)", () => {
      const wrapper = document.querySelector('.component_ambassadors_list');
      const cards = document.querySelectorAll('.component_ambassadors_list-item');
      cards.forEach((card, i) => {
        const isOdd = (i + 1) % 2 !== 0;
        gsap.to(card, {
          y: isOdd ? 80 : -80,
          ease: 'none',
          scrollTrigger: { trigger: wrapper, start: 'top bottom', end: 'bottom top', scrub: isOdd ? 2 : 1 },
        });
      });
      return () => { cards.forEach(card => gsap.set(card, { clearProps: 'y' })); };
    });
  });
</script>
        </div>
        <div class="padding-global padding-section-large">
          <div class="container-large">
            <div class="component_heading_split">
              <h2 class="text-color-primary">{{ section.settings.heading | default: 'OUR AMBASSADORS' }}</h2>
              <p id="w-node-bf55dd09-238b-a049-25b1-be6501456b06-01456aff" class="text-color-primary">{{ section.settings.body | default: 'A powerhouse collective from every corner of sport, our ambassadors wear Sparms with pride in training, on the field, and at every competition.' }}</p>
            </div>
            <div class="spacer-xxlarge"></div>
            <div class="component_ambassadors_list">
              {%- for block in section.blocks -%}
                {%- if block.type == 'ambassador' -%}
                  {%- liquid
                    if block.settings.photo != blank
                      assign photo_url = block.settings.photo | image_url: width: 800
                    else
                      assign photo_url = block.settings.photo_filename | default: 'Ambassadors-Image.webp' | asset_url
                    endif
                    if block.settings.country_flag != blank
                      assign flag_url = block.settings.country_flag | image_url: width: 80
                    else
                      assign flag_url = block.settings.country_flag_filename | default: 'au.webp' | asset_url
                    endif
                  -%}
                  <div class="component_ambassadors_list-item" {{ block.shopify_attributes }}>
                    <div class="component_ambassadors_card">
                      <div class="component_ambassadors_img-wrap"><img loading="lazy" src="{{ photo_url }}" alt="{{ block.settings.name | escape }}" class="component_ambassadors_img"></div>
                      <div class="component_ambassadors_content">
                        <div class="component_ambassadors_name-wrap">
                          <div class="component_collection_icon-wrap">
                            <div class="icon-embed-xxsmall w-embed"><svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 17 17" fill="none" preserveaspectratio="xMidYMid meet" aria-hidden="true" role="img">
                                <circle cx="8.5" cy="8.5" r="8.5" fill="currentColor"></circle>
                              </svg></div>
                          </div>
                          <div class="text-size-medium text-style-allcaps">{{ block.settings.name | default: 'Angel yin' }}</div>
                        </div>
                        <div class="component_ambasadors_tag-wrap">
                          {%- if block.settings.sport != blank -%}
                            <div class="component_ambassadors_tag">
                              <div>{{ block.settings.sport }}</div>
                            </div>
                          {%- endif -%}
                          {%- if block.settings.country_label != blank -%}
                            <div class="component_ambassadors_tag">
                              <div class="compnent_ambassadors_country-icon"><img loading="lazy" src="{{ flag_url }}" alt=""></div>
                              <div>{{ block.settings.country_label }}</div>
                            </div>
                          {%- endif -%}
                        </div>
                      </div>
                    </div>
                  </div>
                {%- endif -%}
              {%- else -%}
                {%- for i in (1..13) -%}
                  <div class="component_ambassadors_list-item">
                    <div class="component_ambassadors_card">
                      <div class="component_ambassadors_img-wrap"><img loading="lazy" src="{{ 'Ambassadors-Image.webp' | asset_url }}" alt="" class="component_ambassadors_img"></div>
                      <div class="component_ambassadors_content">
                        <div class="component_ambassadors_name-wrap">
                          <div class="component_collection_icon-wrap">
                            <div class="icon-embed-xxsmall w-embed"><svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 17 17" fill="none" preserveaspectratio="xMidYMid meet" aria-hidden="true" role="img">
                                <circle cx="8.5" cy="8.5" r="8.5" fill="currentColor"></circle>
                              </svg></div>
                          </div>
                          <div class="text-size-medium text-style-allcaps">Angel yin</div>
                        </div>
                        <div class="component_ambasadors_tag-wrap">
                          <div class="component_ambassadors_tag">
                            <div>Golf</div>
                          </div>
                          <div class="component_ambassadors_tag">
                            <div class="compnent_ambassadors_country-icon"><img loading="lazy" src="{{ 'au.webp' | asset_url }}" alt=""></div>
                            <div>AU</div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                {%- endfor -%}
              {%- endfor -%}
            </div>
          </div>
        </div>
      </section>
{%- endif -%}

{% schema %}
{
  "name": "Ambassadors",
  "tag": "section",
  "class": "shopify-section-component-ambassadors",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show this section", "default": true },
    { "type": "text", "id": "heading", "label": "Heading", "default": "OUR AMBASSADORS" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "A powerhouse collective from every corner of sport, our ambassadors wear Sparms with pride in training, on the field, and at every competition." }
  ],
  "blocks": [
    {
      "type": "ambassador",
      "name": "Ambassador",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Angel Yin" },
        { "type": "text", "id": "sport", "label": "Sport tag", "default": "Golf" },
        { "type": "text", "id": "country_label", "label": "Country code", "default": "AU" },
        { "type": "image_picker", "id": "photo", "label": "Photo (override)" },
        { "type": "text", "id": "photo_filename", "label": "Photo fallback asset filename", "default": "Ambassadors-Image.webp" },
        { "type": "image_picker", "id": "country_flag", "label": "Country flag (override)" },
        { "type": "text", "id": "country_flag_filename", "label": "Flag fallback asset filename", "default": "au.webp" }
      ]
    }
  ],
  "max_blocks": 24,
  "presets": [
    {
      "name": "Ambassadors",
      "blocks": [
        { "type": "ambassador" }, { "type": "ambassador" }, { "type": "ambassador" }, { "type": "ambassador" },
        { "type": "ambassador" }, { "type": "ambassador" }, { "type": "ambassador" }, { "type": "ambassador" },
        { "type": "ambassador" }, { "type": "ambassador" }, { "type": "ambassador" }, { "type": "ambassador" },
        { "type": "ambassador" }
      ]
    }
  ]
}
{% endschema %}
