{%- if section.settings.show_section -%}
      <section class="component_ambassadors_section">
        <div class="w-embed w-script">
          <style>
/* 992px to 1240px — 3 columns */
@media (min-width: 992px) and (max-width: 1239px) {
  .component_ambassadors_list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    align-items: start;
  }
  /* Column 2 only — same stagger effect for 3 cols */
  .component_ambassadors_list-item:nth-child(3n+2) {
    margin-top: 200px;
    margin-left: -25%;
  }
  /* All cards overlap */
  .component_ambassadors_list-item {
    margin-bottom: -80px;
  }
  /* First 3 cards — extra overlap */
  .component_ambassadors_list-item:nth-child(1),
  .component_ambassadors_list-item:nth-child(2),
  .component_ambassadors_list-item:nth-child(3) {
    margin-bottom: -120px;
  }
}
/* 1240px and above — 4 columns */
@media (min-width: 1240px) {
  .component_ambassadors_list {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    align-items: start;
  }
  /* Column 2 and 4 — stagger effect */
  .component_ambassadors_list-item:nth-child(4n+2),
  .component_ambassadors_list-item:nth-child(4n+4) {
    margin-top: 200px;
    margin-left: -25%;
  }
  /* All cards overlap */
  .component_ambassadors_list-item {
    margin-bottom: -80px;
  }
  /* First 3 cards — extra overlap */
  .component_ambassadors_list-item:nth-child(1),
  .component_ambassadors_list-item:nth-child(2),
  .component_ambassadors_list-item:nth-child(3) {
    margin-bottom: -120px;
  }
}
  </style>
          <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>
          <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js"></script>
          <script>
  document.addEventListener('DOMContentLoaded', () => {
    gsap.registerPlugin(ScrollTrigger);
    const mm = gsap.matchMedia();
    mm.add("(min-width: 992px)", () => {
      const wrapper = document.querySelector('.component_ambassadors_list');
      const cards = document.querySelectorAll('.component_ambassadors_list-item');
      cards.forEach((card, i) => {
        const isOdd = (i + 1) % 2 !== 0;  // 1st, 3rd, 5th... go down
        const isEven = (i + 1) % 2 === 0; // 2nd, 4th, 6th... go up
        gsap.to(card, {
          y: isOdd ? 80 : -80, // odd = down, even = up
          ease: 'none',
          scrollTrigger: {
            trigger: wrapper,
            start: 'top bottom',
            end: 'bottom top',
            scrub: isOdd ? 2 : 1, // odd = slower, even = snappier
          },
        });
      });
      // Cleanup below 992px
      return () => {
        cards.forEach(card => gsap.set(card, { clearProps: 'y' }));
      };
    });
  });
</script>
