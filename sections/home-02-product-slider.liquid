              <script>
  document.addEventListener('DOMContentLoaded', function () {
    const swiper = new Swiper('#is-product', {
      spaceBetween: 16,
      navigation: {
        nextEl: '#product-swiper-next',
        prevEl: '#product-swiper-prev',
      },
      breakpoints: {
        0: {
          enabled: false,
          slidesPerView: 'auto',
          spaceBetween: 0,
        },
        992: {
          enabled: true,
          slidesPerView: 'auto',
          spaceBetween: 32,
        },
      },
    });
  });
</script>
              <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>
              <script>
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll('.button.is-add-to-cart');
    const panels = document.querySelectorAll('.component_product-list_size-wrapper');
    // Hide all panels on load
    gsap.set(panels, { autoAlpha: 0 });
    triggers.forEach((trigger, i) => {
      const panel = panels[i]; // match each trigger to its own panel
      // Open on click
      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        // Close all other panels first
        panels.forEach((p) => {
          if (p !== panel) {
            gsap.to(p, { autoAlpha: 0, duration: 0.2, ease: 'power2.in' });
          }
        });
        // Toggle this panel
        const isVisible = gsap.getProperty(panel, 'autoAlpha') === 1;
        gsap.to(panel, {
          autoAlpha: isVisible ? 0 : 1,
          duration: 0.3,
          ease: isVisible ? 'power2.in' : 'power2.out',
        });
      });
    });
    // Close all panels when clicking outside
    document.addEventListener('click', (e) => {
      const clickedOutside = ![...triggers, ...panels].some(el => el.contains(e.target));
      if (clickedOutside) {
        gsap.to(panels, { autoAlpha: 0, duration: 0.2, ease: 'power2.in' });
      }
    });
    // Close all panels when tapping outside on mobile
    document.addEventListener('touchstart', (e) => {
      const tappedOutside = ![...triggers, ...panels].some(el => el.contains(e.target));
      if (tappedOutside) {
        gsap.to(panels, { autoAlpha: 0, duration: 0.2, ease: 'power2.in' });
      }
    });
  });
</script>
