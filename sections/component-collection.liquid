          <script>
  document.addEventListener('DOMContentLoaded', () => {
    const isCollectionSwiper = new Swiper('#is-collection', {
      direction: 'vertical',
      slidesPerView: 5,
      centeredSlides: true,
      mousewheel: true,
      speed: 500,
      keyboard: {
        enabled: true,
      },
      breakpoints: {
        0: {
          direction: 'horizontal',
          slidesPerView: 1,
          spaceBetween: 16,
          mousewheel: false,
        },
        992: {
          direction: 'vertical',
          slidesPerView: 'auto',
          spaceBetween: 0,
          mousewheel: true,
        },
      },
    });
  });
</script>
          <script>
  document.addEventListener('DOMContentLoaded', () => {
    const destination = document.querySelector('#destination');
    function syncText() {
      const activeSource = document.querySelector('.swiper-slide-active .text-source');
      if (activeSource && destination) {
        destination.textContent = activeSource.textContent;
      }
    }
    // Initial sync
    syncText();
    // Watch for swiper-slide-active class changes dynamically
    const observer = new MutationObserver(syncText);
    observer.observe(document.querySelector('#is-collection'), {
      attributes: true,
      subtree: true,
      attributeFilter: ['class'],
    });
  });
</script>
