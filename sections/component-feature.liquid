{%- if section.settings.show_section -%}
      <section class="component_feature_section">
        <div class="component_feature_top">
          <div class="component_feature_logo-wrap"><img src="{{ 'sparms-logo-wordmark.png' | asset_url }}" loading="lazy" sizes="(max-width: 2160px) 100vw, 2160px" srcset="{{ 'sparms-logo-wordmark-p-500.png' | asset_url }} 500w, {{ 'sparms-logo-wordmark-p-800.png' | asset_url }} 800w, {{ 'sparms-logo-wordmark-p-1080.png' | asset_url }} 1080w, {{ 'sparms-logo-wordmark-p-1600.png' | asset_url }} 1600w, {{ 'sparms-logo-wordmark-p-2000.png' | asset_url }} 2000w, {{ 'sparms-logo-wordmark.png' | asset_url }} 2160w" alt=""></div>
          <div class="spacer-xxlarge"></div>
          <div class="padding-global">
            <div class="container-large">
              <div class="component_heading_split">
                <h2>the sporting advantage</h2>
                <div id="w-node-aae64b67-93d9-9131-8253-5487d50c4b50-6832ed3c" class="component_heading_description">
                  <p>The Original sun sleeve, and the choice of champions, Sparms is trusted by elite athletes worldwide. Our lightweight, breathable fabrics are designed to enhance, not limit. Get the best protection for your every day.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="component_feature_body">
          <div class="padding-global padding-section-large">
            <div class="container-large">
              <div class="component_feature_body-content">
                <div class="hide w-embed w-script">
                  <script>
  document.addEventListener('DOMContentLoaded', function () {
    const swiper = new Swiper('#is-feature', {
      spaceBetween: 16,
      navigation: {
        nextEl: '#feature-swiper-next',
        prevEl: '#feature-swiper-prev',
      },
      breakpoints: {
        0: {
          enabled: true,
          slidesPerView: 1,
          spaceBetween: 16,
        },
        992: {
          enabled: false,
          slidesPerView: 'auto',
          spaceBetween: 32,
        },
      },
    });
  });
</script>
                </div>
                <div class="component_feature_swiper-wrap">
                  <div id="is-feature" class="swiper is-feature">
                    <div class="swiper-wrapper is-feature">
                      <div id="w-node-f1651195-a419-79af-3780-f2b900556a86-6832ed3c" class="swiper-slide">
                        <div class="component_feature_card">
                          <div class="component_feature_title-wrap">
                            <h3 class="home_feature_title">Proven SPF 50+ Protection</h3>
                            <div class="home_feature_icon-wrap w-embed"><svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 13 13" fill="none" preserveaspectratio="xMidYMid meet" aria-hidden="true" role="img">
                                <circle cx="6.5" cy="6.5" r="6.5" fill="currentColor"></circle>
                              </svg></div>
                          </div>
                          <div class="component_feature_card-body">
                            <p class="paragraph">Claiming to have the best sun sleeves is bold, but we back it up.  Every year, our products are independently certified and rigorously tested to give you the ultimate UV defence. When you choose Sparms, you’re choosing protection you can trust.</p>
                          </div>
                        </div>
                      </div>
                      <div id="w-node-_8a5bf798-6761-a3fc-6061-d6178265f9c7-6832ed3c" class="swiper-slide is-feature">
                        <div class="component_feature_card is-feature-right">
                          <div class="component_feature_title-wrap is-right-aligned">
                            <div class="home_feature_icon-wrap w-embed"><svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 13 13" fill="none" preserveaspectratio="xMidYMid meet" aria-hidden="true" role="img">
                                <circle cx="6.5" cy="6.5" r="6.5" fill="currentColor"></circle>
                              </svg></div>
                            <h3 class="home_feature_title">Stay Cool Under Pressure</h3>
                          </div>
                          <div class="component_feature_card-body is-right-aligned">
                            <p class="paragraph">Our proprietary process harnesses the moisture-wicking power of premium fabrics, delivering a cooling, effortless fit from the moment you put it on. Whether you’re under the midday sun or pushing through an intense session, our sleeves keep you fresh, focused and moving at your best.</p>
                          </div>
                        </div>
                      </div>
                      <div id="w-node-_0c45e353-c92f-64e5-2724-abce473ff976-6832ed3c" class="swiper-slide is-feature">
                        <div class="component_feature_card">
                          <div class="component_feature_title-wrap">
                            <h3 class="home_feature_title">The Style in SPF</h3>
                            <div class="home_feature_icon-wrap w-embed"><svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 13 13" fill="none" preserveaspectratio="xMidYMid meet" aria-hidden="true" role="img">
                                <circle cx="6.5" cy="6.5" r="6.5" fill="currentColor"></circle>
                              </svg></div>
                          </div>
                          <div class="component_feature_card-body">
                            <p class="paragraph">Designed for athletes who demand more than just function, our sleeves keep you cool, protected, and looking sharp while you push your limits.</p>
                          </div>
                        </div>
                      </div>
                      <div id="w-node-_4e5d2765-dc2a-b7e0-f257-5cf6531bb0b1-6832ed3c" class="swiper-slide is-feature">
                        <div class="component_feature_card is-feature-right">
                          <div class="component_feature_title-wrap is-right-aligned">
                            <div class="home_feature_icon-wrap w-embed"><svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 13 13" fill="none" preserveaspectratio="xMidYMid meet" aria-hidden="true" role="img">
                                <circle cx="6.5" cy="6.5" r="6.5" fill="currentColor"></circle>
                              </svg></div>
                            <h3 class="home_feature_title">The Style in SPF</h3>
                          </div>
                          <div class="component_feature_card-body is-right-aligned">
                            <p class="paragraph">With a wide range of sizes, every piece stays in place, supporting your performance and letting you focus on the play. Engineered for every body and designed to look as sharp as it feels, Sparms keeps you ready for whatever the day throws at you.</p>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="swiper_arrow_wrapper is-feature">
                    <div id="feature-swiper-prev" class="swiper_arrow is-dark">
                      <div class="icon-embed-blogs w-embed"><svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 24 24" fill="none" preserveaspectratio="xMidYMid meet" aria-hidden="true" role="img">
                          <path d="M12.7069 17.293L8.41394 13H17.9999V11H8.41394L12.7069 6.70697L11.2929 5.29297L4.58594 12L11.2929 18.707L12.7069 17.293Z" fill="currentColor"></path>
                        </svg></div>
                    </div>
                    <div id="feature-swiper-next" class="swiper_arrow is-dark">
                      <div class="icon-embed-blogs is-reversed w-embed"><svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 24 24" fill="none" preserveaspectratio="xMidYMid meet" aria-hidden="true" role="img">
                          <path d="M12.7069 17.293L8.41394 13H17.9999V11H8.41394L12.7069 6.70697L11.2929 5.29297L4.58594 12L11.2929 18.707L12.7069 17.293Z" fill="currentColor"></path>
                        </svg></div>
                    </div>
                  </div>
                </div>
                <div class="button-group">
                  <a href="#" class="button is-secondary is-icon w-inline-block">
                    <div class="button-icon w-embed"><svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 13 13" fill="none" preserveaspectratio="xMidYMid meet" aria-hidden="true" role="img">
                        <circle cx="6.5" cy="6.5" r="6.5" fill="currentColor"></circle>
                      </svg></div>
                    <div>View collection</div>
                  </a>
                  <a href="#" class="button is-link is-icon w-inline-block">
                    <div>Shop All</div>
                    <div class="icon-embed-blogs w-embed"><svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 24 24" fill="none" preserveaspectratio="xMidYMid meet" aria-hidden="true" role="img">
                        <path d="M9.70697 16.9496L15.414 11.2426L9.70697 5.53564L8.29297 6.94964L12.586 11.2426L8.29297 15.5356L9.70697 16.9496Z" fill="currentColor"></path>
                      </svg></div>
                  </a>
                </div>
              </div>
            </div>
          </div>
          <div class="component_feature_body-img-wrap"><img src="{{ 'Feature-background-Image.webp' | asset_url }}" loading="lazy" sizes="100vw" srcset="{{ 'Feature-background-Image-p-500.webp' | asset_url }} 500w, {{ 'Feature-background-Image-p-800.webp' | asset_url }} 800w, {{ 'Feature-background-Image-p-1080.webp' | asset_url }} 1080w, {{ 'Feature-background-Image-p-1600.webp' | asset_url }} 1600w, {{ 'Feature-background-Image-p-2000.webp' | asset_url }} 2000w, {{ 'Feature-background-Image.webp' | asset_url }} 2160w" alt="" class="home_feature_body-img"></div>
        </div>
      </section>
{%- endif -%}

{% schema %}
{
  "name": "Feature",
  "tag": "section",
  "class": "shopify-section-component-feature",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show this section",
      "default": true
    },
    {
      "type": "paragraph",
      "content": "Imported from Webflow. To make text/images editable, add settings here or split into blocks — see CONVERSION_GUIDE §6.1."
    }
  ],
  "presets": [
    {
      "name": "Feature"
    }
  ]
}
{% endschema %}
