{%- if section.settings.show_section -%}
<section class="page-product-stub padding-global padding-section-medium">
  <div class="container-large">
    <div class="text-align-center">
      <h1>{{ section.settings.heading | default: 'Product' }}</h1>
      <div class="spacer-medium"></div>
      <p>{{ section.settings.body | default: 'Product details will appear here once a product is assigned.' }}</p>
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Page — Product",
  "tag": "section",
  "class": "shopify-section-page-product",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show this section", "default": true },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Product" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Product details will appear here once a product is assigned." },
    { "type": "paragraph", "content": "Stub section — wire up commerce / dynamic content per CONVERSION_GUIDE §7." }
  ],
  "presets": [{ "name": "Page — Product" }]
}
{% endschema %}
