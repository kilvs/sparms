{%- if section.settings.show_section -%}
<section class="page-blog-stub padding-global padding-section-medium">
  <div class="container-large">
    <div class="text-align-center">
      <h1>{{ section.settings.heading | default: 'Blog' }}</h1>
      <div class="spacer-medium"></div>
      <p>{{ section.settings.body | default: 'Blog post list will appear here once articles are published.' }}</p>
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Page — Blog",
  "tag": "section",
  "class": "shopify-section-page-blog",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show this section", "default": true },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Blog" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Blog post list will appear here once articles are published." },
    { "type": "paragraph", "content": "Stub section — wire up commerce / dynamic content per CONVERSION_GUIDE §7." }
  ],
  "presets": [{ "name": "Page — Blog" }]
}
{% endschema %}
