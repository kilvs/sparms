{%- comment -%}
  PLACEHOLDERS to fill in:
  - <YOUR_WF_SITE_ID>           — constant `data-wf-site` from your Webflow export (find via: grep -o 'data-wf-site="[^"]*"' index.html | head -1)
  - <WF_PAGE_*>                 — per-template `data-wf-page` IDs (find via: for f in *.html; do echo "$f: $(grep -o 'data-wf-page="[^"]*"' $f | head -1)"; done)
  - WEBFLOW_BUNDLE              — the name of the Webflow JS file in assets/ (e.g. site-dev.js, brand-dev.js)
  - WEBFLOW_SITE_BUNDLE_QS      — the ?site= query string suffix Webflow puts on jQuery (matches your data-wf-site)
  - normalize.css / components.css / site.css — your CSS files in assets/
{%- endcomment -%}
{%- liquid
  case template
    when 'index'
      assign wf_page_id = '<WF_PAGE_INDEX>'
    when 'product'
      assign wf_page_id = '<WF_PAGE_PRODUCT>'
    when 'collection'
      assign wf_page_id = '<WF_PAGE_COLLECTION>'
    when 'blog'
      assign wf_page_id = '<WF_PAGE_BLOG>'
    when 'article'
      assign wf_page_id = '<WF_PAGE_ARTICLE>'
    when 'page.about'
      assign wf_page_id = '<WF_PAGE_ABOUT>'
    when 'page.contact'
      assign wf_page_id = '<WF_PAGE_CONTACT>'
    when 'page'
      assign wf_page_id = '<WF_PAGE_GENERIC_PAGE>'
    when '404'
      assign wf_page_id = '<WF_PAGE_404>'
    else
      assign wf_page_id = '<WF_PAGE_INDEX>'
  endcase
-%}
<!DOCTYPE html>
<html data-wf-page="{{ wf_page_id }}" data-wf-site="<YOUR_WF_SITE_ID>" lang="{{ request.locale.iso_code | default: 'en' }}">
<head>
  <meta charset="utf-8">
  <title>{{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}{% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>
  {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}
  <meta content="width=device-width, initial-scale=1" name="viewport">
  <link rel="canonical" href="{{ canonical_url }}">

  {{ 'normalize.css' | asset_url | stylesheet_tag }}
  {{ 'components.css' | asset_url | stylesheet_tag }}
  {{ 'site.css' | asset_url | stylesheet_tag }}{%- comment -%} ⇐ rename to your site's CSS file {%- endcomment -%}
  {{ 'cart-drawer.css' | asset_url | stylesheet_tag }}
  {% render 'theme-variables' %}

  <script>window.Shopify = window.Shopify || {}; Shopify.routes = { root: '{{ routes.root_url }}' }; Shopify.money_format = {{ shop.money_format | json }};</script>
  {%- if settings.seo_default_description != blank and page_description == blank -%}
    <meta name="description" content="{{ settings.seo_default_description | escape }}">
  {%- endif -%}
  {%- if settings.social_share_image != blank -%}
    <meta property="og:image" content="{{ settings.social_share_image | image_url: width: 1200 }}">
    <meta name="twitter:card" content="summary_large_image">
  {%- endif -%}

  {%- comment -%} Webflow JS detector — force w-mod-ix3 so interaction-aware CSS rules apply unconditionally. {%- endcomment -%}
  <script type="text/javascript">!function(o,c){var n=c.documentElement,t=" w-mod-";n.className+=t+"js"+t+"ix3",("ontouchstart"in o||o.DocumentTouch&&c instanceof DocumentTouch)&&(n.className+=t+"touch")}(window,document);</script>

  {%- if settings.favicon != blank -%}
    <link rel="shortcut icon" href="{{ settings.favicon | image_url: width: 32 }}" type="image/png">
    <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180 }}">
  {%- else -%}
    <link rel="shortcut icon" href="{{ 'favicon.png' | asset_url }}" type="image/png">
    <link rel="apple-touch-icon" href="{{ 'webclip.png' | asset_url }}">
  {%- endif -%}

  {%- comment -%} If your export uses Swiper, include the CDN here. {%- endcomment -%}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
  <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

  {%- comment -%}
    Inline Swiper helpers + per-export init helpers go here.
    Lift them verbatim from any of your source HTML pages' <head> <script> blocks
    (they're identical across pages).
  {%- endcomment -%}

  {{ content_for_header }}
</head>
<body class="template-{{ template.name | handle }}{% if template.suffix %} template-suffix-{{ template.suffix | handle }}{% endif %}">
  <div class="page-wrapper">
    {%- comment -%}
      If your export has a cursor element / global-styles inline <style> block
      / other page-wrapper-level content, lift it verbatim from any source
      HTML page (e.g. index.html lines ~200-420) and paste here.
    {%- endcomment -%}

    {% sections 'header-group' %}

    {{ content_for_layout }}

    {% sections 'footer-group' %}
  </div>
  {% render 'cart-drawer' %}

  <script src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=<YOUR_WF_SITE_ID>" type="text/javascript" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
  <script src="{{ '<WEBFLOW_BUNDLE>.js' | asset_url }}" type="text/javascript"></script>{%- comment -%} ⇐ your site's main Webflow JS bundle {%- endcomment -%}
  <script src="https://cdn.prod.website-files.com/gsap/3.15.0/gsap.min.js" type="text/javascript"></script>
  <script src="https://cdn.prod.website-files.com/gsap/3.15.0/SplitText.min.js" type="text/javascript"></script>
  <script src="https://cdn.prod.website-files.com/gsap/3.15.0/ScrollTrigger.min.js" type="text/javascript"></script>
  <script src="{{ 'cart-ajax.js' | asset_url }}" defer></script>
</body>
</html>
