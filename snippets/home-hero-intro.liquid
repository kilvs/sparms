<script>
window.Webflow = window.Webflow || [];
window.Webflow.push(function () {
  var loadEl = document.querySelector('.home_hero_load');
  function hideLoadEl() { if (loadEl) loadEl.style.display = 'none'; }

  var hasSeenIntro = sessionStorage.getItem('introPlayed');
  if (hasSeenIntro) {
    gsap.set('.home_hero_blue-dot', { autoAlpha: 0, scale: 1 });
    gsap.set('.home_logo_svg-wrap', { opacity: 1, scale: 100 });
    hideLoadEl();
    return;
  }
  sessionStorage.setItem('introPlayed', 'true');

  var tl = gsap.timeline({ onComplete: hideLoadEl });
  tl.fromTo('.home_hero_blue-dot',
    { scale: 0, opacity: 1 },
    { scale: 1, opacity: 1, duration: 0.5, ease: 'back.out(1.7)' },
  0)
  .fromTo('.home_hero_blue-dot',
    { opacity: 1 },
    { opacity: 0, duration: 0.5 },
  1.5)
  .fromTo('.home_logo_svg-wrap',
    { opacity: 0, scale: 1 },
    { opacity: 0, scale: 1, duration: 0 },
  0)
  .fromTo('.home_logo_svg-wrap',
    { opacity: 0, scale: 1 },
    { opacity: 1, scale: 1, duration: 0.5 },
  1.5)
  .fromTo('.home_logo_svg-wrap',
    { scale: 1 },
    { scale: 100, duration: 2.5, ease: 'linear' },
  3.0)
  .fromTo('.home_hero_load',
    { autoAlpha: 1 },
    { autoAlpha: 0, duration: 0.75 },
  3.75);
});
</script>
